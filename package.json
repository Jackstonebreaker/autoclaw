{
  "name": "autoclaw",
  "version": "0.1.0",
  "description": "CLI tool that automates code improvement by extracting patterns and generating rules",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "autoclaw": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "code-improvement",
    "ai",
    "rules",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
